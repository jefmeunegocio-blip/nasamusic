{
  "entities": {
    "SchoolConfig": {
      "title": "School Configuration",
      "description": "General settings and config for the music school",
      "type": "object",
      "properties": {
        "logoName": { "type": "string" },
        "schoolName": { "type": "string" },
        "tagline": { "type": "string" },
        "whatsapp": { "type": "string" },
        "instagram": { "type": "string" },
        "facebook": { "type": "string" },
        "youtube": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "aboutText": { "type": "string" },
        "videoUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "whatsappMessage": { "type": "string" }
      },
      "required": ["schoolName", "whatsapp"]
    },
    "Course": {
      "title": "Course",
      "description": "A musical course offered by the school",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "duration": { "type": "string" },
        "level": { "type": "string" },
        "image": { "type": "string" },
        "features": { "type": "array" }
      },
      "required": ["id", "name", "description"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Subscription or pricing plan for the school",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "period": { "type": "string" },
        "popular": { "type": "boolean" },
        "features": { "type": "array" },
        "buttonText": { "type": "string" }
      },
      "required": ["id", "name", "price"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "An instructor/teacher at the school",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "specialties": { "type": "array" },
        "social": { "type": "object" }
      },
      "required": ["id", "name", "role"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "An image or item in the photo gallery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "image"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "An article or blog post published by the school",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "readTime": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array" },
        "author": { "type": "object" }
      },
      "required": ["id", "title", "content"]
    },
    "FAQItem": {
      "title": "FAQ Item",
      "description": "Frequently Asked Question item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "question", "answer"]
    },
    "StudyMaterial": {
      "title": "Study Material",
      "description": "Educational resource or download for students",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["id", "title", "downloadUrl"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "General announcement for students and parents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "priority": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "title", "content"]
    },
    "ClassCalendarEvent": {
      "title": "Class Calendar Event",
      "description": "An event scheduled in the school calendar",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "allDay": { "type": "boolean" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "courseId": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "title", "start", "end"]
    }
  },
  "firestore": {
    "/config/{configId}": {
      "schema": "SchoolConfig",
      "description": "School configuration parameters"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Offered music courses"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "School subscription plans"
    },
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teaching staff members"
    },
    "/gallery/{galleryId}": {
      "schema": "GalleryItem",
      "description": "Photo gallery items"
    },
    "/blog/{postId}": {
      "schema": "BlogPost",
      "description": "School news and blog articles"
    },
    "/faq/{faqId}": {
      "schema": "FAQItem",
      "description": "Frequently Asked Questions"
    },
    "/materials/{materialId}": {
      "schema": "StudyMaterial",
      "description": "Study and sheet music downloads"
    },
    "/announcements/{annId}": {
      "schema": "Announcement",
      "description": "School announcements"
    },
    "/calendar/{eventId}": {
      "schema": "ClassCalendarEvent",
      "description": "Scheduled events calendar"
    }
  }
}
